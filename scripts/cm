#!/bin/bash
#
# cm - Check messages
# 
# SINGLE SOURCE OF TRUTH for inter-agent messaging.
# Reads from ONE place: .agents/queue/todo/
#
# Usage: cm
#
# This is the ONLY way to receive messages. All agents MUST run this:
#   1. At session start
#   2. Before going idle

set -e

cd "$(dirname "$0")/../.." 2>/dev/null || cd "$(pwd)"

TODO_DIR=".agents/queue/todo"

if [ -d "$TODO_DIR" ] && [ "$(ls -A "$TODO_DIR" 2>/dev/null)" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  📬 NEW TASKS                                                ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    
    for task in "$TODO_DIR"/*.md; do
        [ -f "$task" ] || continue
        echo "--- $(basename "$task") ---"
        head -40 "$task"
        echo ""
    done
    
    echo "Run 'agent-task claim <filename>' to claim a task"
    echo ""
else
    echo ""
    echo "No new tasks."
    echo ""
fi
