#!/bin/bash
#
# agent-setup - Onboarding script for Inter-Agent Messaging
#
# Usage: agent-setup [project-path...]
#
# Performs TWO installations:
# 1. SKILL INSTALLATION: Symlinks skill to ~/.config/agents/skills/ (for Kimi discovery)
# 2. TOOLS INSTALLATION: Symlinks tools to ~/.local/bin/ (for execution)
#
# Also sets up:
# - Global queue directory structure
# - Config directory
# - Registers specified projects

set -e

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SKILL_NAME="inter-agent-messaging"
GLOBAL_QUEUE="$HOME/.local/share/kimi/queue"
CONFIG_DIR="$HOME/.config/kimi/inter-agent-messaging"
BIN_DIR="$HOME/.local/bin"
SKILLS_DIR="$HOME/.config/agents/skills"

echo "=========================================="
echo "Inter-Agent Messaging v3.0 Setup"
echo "=========================================="
echo ""
echo "This script performs TWO installations:"
echo "  1. Skill → ~/.config/agents/skills/ (Kimi discovery)"
echo "  2. Tools → ~/.local/bin/ (execution)"
echo ""

# ============================================================================
# 1. SKILL INSTALLATION (for Kimi to discover)
# ============================================================================

echo "📦 Installing skill for Kimi discovery..."

mkdir -p "$SKILLS_DIR"

if [ -L "$SKILLS_DIR/$SKILL_NAME" ]; then
    echo "   ✓ Skill already linked at $SKILLS_DIR/$SKILL_NAME"
elif [ -e "$SKILLS_DIR/$SKILL_NAME" ]; then
    echo "   ⚠️  Skill exists (not a symlink). Backing up..."
    mv "$SKILLS_DIR/$SKILL_NAME" "$SKILLS_DIR/${SKILL_NAME}.backup.$(date +%s)"
    ln -s "$SKILL_DIR" "$SKILLS_DIR/$SKILL_NAME"
    echo "   ✓ Skill linked"
else
    ln -s "$SKILL_DIR" "$SKILLS_DIR/$SKILL_NAME"
    echo "   ✓ Skill linked: $SKILLS_DIR/$SKILL_NAME"
    echo "     → $SKILL_DIR"
fi

# ============================================================================
# 2. TOOLS INSTALLATION (for execution)
# ============================================================================

echo ""
echo "🔧 Installing tools to ~/.local/bin/..."

mkdir -p "$BIN_DIR"

# cm
if [ -L "$BIN_DIR/cm" ]; then
    echo "   ✓ cm already linked"
elif [ -e "$BIN_DIR/cm" ]; then
    echo "   ⚠️  cm exists (not a symlink). Backing up to cm.backup"
    mv "$BIN_DIR/cm" "$BIN_DIR/cm.backup"
    ln -s "$SKILL_DIR/scripts/cm" "$BIN_DIR/cm"
    echo "   ✓ cm linked"
else
    ln -s "$SKILL_DIR/scripts/cm" "$BIN_DIR/cm"
    echo "   ✓ cm linked"
fi

# agent-task
if [ -L "$BIN_DIR/agent-task" ]; then
    echo "   ✓ agent-task already linked"
elif [ -e "$BIN_DIR/agent-task" ]; then
    echo "   ⚠️  agent-task exists (not a symlink). Backing up..."
    mv "$BIN_DIR/agent-task" "$BIN_DIR/agent-task.backup"
    ln -s "$SKILL_DIR/scripts/agent-task" "$BIN_DIR/agent-task"
    echo "   ✓ agent-task linked"
else
    ln -s "$SKILL_DIR/scripts/agent-task" "$BIN_DIR/agent-task"
    echo "   ✓ agent-task linked"
fi

# ============================================================================
# 3. SETUP DIRECTORIES
# ============================================================================

echo ""
echo "📁 Creating directory structure..."

# Global queue
mkdir -p "$GLOBAL_QUEUE"/{todo,doing,done,.locks}
echo "   ✓ Global queue: $GLOBAL_QUEUE"

# Config directory
mkdir -p "$CONFIG_DIR"
echo "   ✓ Config directory: $CONFIG_DIR"

# Init projects file if doesn't exist
if [ ! -f "$CONFIG_DIR/projects" ]; then
    echo "# Registered project paths for inter-agent-messaging" > "$CONFIG_DIR/projects"
    echo "# One absolute path per line" >> "$CONFIG_DIR/projects"
    echo "   ✓ Created projects registry"
fi

# ============================================================================
# 4. CHECK PATH
# ============================================================================

echo ""
echo "🔍 Checking PATH..."

if [[ ":$PATH:" == *":$BIN_DIR:"* ]]; then
    echo "   ✓ $BIN_DIR is in PATH"
else
    echo "   ⚠️  $BIN_DIR is NOT in PATH"
    echo ""
    echo "   Add this to your ~/.bashrc or ~/.zshrc:"
    echo "   export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo ""
fi

# ============================================================================
# 5. REGISTER PROJECTS
# ============================================================================

echo ""
if [ $# -eq 0 ]; then
    echo "💡 No projects specified for registration."
    echo "   Register projects later with:"
    echo "   agent-task register-project /path/to/project"
else
    echo "📂 Registering projects..."
    for project_path in "$@"; do
        if [ -d "$project_path" ]; then
            # Ensure PATH is set for this session
            export PATH="$BIN_DIR:$PATH"
            agent-task register-project "$project_path"
        else
            echo "   ⚠️  Directory not found: $project_path"
        fi
    done
fi

# ============================================================================
# 6. VERIFY
# ============================================================================

echo ""
echo "=========================================="
echo "Setup Complete!"
echo "=========================================="
echo ""

# Test skill installation
if [ -L "$SKILLS_DIR/$SKILL_NAME" ]; then
    echo "✅ Skill installed: $SKILLS_DIR/$SKILL_NAME"
    echo "   Kimi will discover this skill on next start"
else
    echo "⚠️  Skill installation issue"
fi

# Test tools
echo ""
echo "🧪 Testing tools..."

if [ -L "$BIN_DIR/cm" ] && [ -x "$BIN_DIR/cm" ]; then
    echo "   ✓ cm installed"
else
    echo "   ⚠️  cm not properly installed"
fi

if [ -L "$BIN_DIR/agent-task" ] && [ -x "$BIN_DIR/agent-task" ]; then
    echo "   ✓ agent-task installed"
else
    echo "   ⚠️  agent-task not properly installed"
fi

if [[ ":$PATH:" == *":$BIN_DIR:"* ]]; then
    echo "   ✓ PATH configured"
else
    echo "   ⚠️  PATH not configured (see above)"
fi

echo ""
echo "📖 Quick start:"
echo "   cm                           # Check all messages"
echo "   agent-task projects          # List registered projects"
echo "   agent-task create 'Task' me  # Create a task"
echo ""
echo "📚 Documentation:"
echo "   SKILL.md    - Complete skill guide (Kimi reads this)"
echo "   README.md   - Quick reference"
echo ""
