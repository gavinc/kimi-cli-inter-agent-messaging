#!/bin/bash
#
# dm - Direct Message Notification
# 
# PURPOSE: Notify an agent to check their queue.
# 
# The notification appears in the agent's context without breaking their flow.
# The recipient runs 'cm' to see the actual tasks.
#
# Usage: dm <agent-name>
# Example: dm testing-agent

set -e

TARGET="$1"

if [ -z "$TARGET" ]; then
    echo "Usage: dm <agent-name>"
    echo "Example: dm testing-agent"
    echo ""
    echo "NOTE: Create task file FIRST:"
    echo "  echo 'task content' > .agents/queue/todo/YYYY-MM-DD-task.md"
    echo "  dm testing-agent"
    exit 1
fi

# Remove @ if present
TARGET="${TARGET#@}"

# Find target pane
PANE_INFO=$(tmux list-panes -a -F '#{pane_id} #{pane_title}' 2>/dev/null | \
    grep -E ": ${TARGET}$" | head -1 || true)

if [ -z "$PANE_INFO" ]; then
    echo "[!] Agent '$TARGET' not found"
    exit 1
fi

PANE_ID=$(echo "$PANE_INFO" | awk '{print $1}')

# Send notification (appears in agent's context without interrupting)
tmux send-keys -t "$PANE_ID" "📨 New task from ${AGENT_NAME:-sender}. Run: cm" Enter

echo "✅ Notified @$TARGET"
