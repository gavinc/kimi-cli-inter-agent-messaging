#!/bin/bash
#
# dm - Direct Message Notification
# 
# PURPOSE: Ping an agent to run 'cm' and check their queue.
# 
# IMPORTANT: This does NOT create messages. It ONLY sends a notification.
# Create task files FIRST, then optionally use dm to notify.
#
# Usage: dm <agent-name>
# Example: dm testing-agent

set -e

TARGET="$1"

if [ -z "$TARGET" ]; then
    echo "Usage: dm <agent-name>"
    echo "Example: dm testing-agent"
    echo ""
    echo "NOTE: Create task file FIRST, then use dm to notify:"
    echo "  echo 'task content' > .agents/queue/todo/YYYY-MM-DD-task.md"
    echo "  dm testing-agent"
    exit 1
fi

# Remove @ if present
TARGET="${TARGET#@}"

# Find target pane
PANE_INFO=$(tmux list-panes -a -F '#{pane_id} #{pane_title}' 2>/dev/null | \
    grep -E ": ${TARGET}$" | head -1 || true)

if [ -z "$PANE_INFO" ]; then
    echo "[!] Agent '$TARGET' not found"
    exit 1
fi

PANE_ID=$(echo "$PANE_INFO" | awk '{print $1}')

# Send notification
tmux send-keys -t "$PANE_ID" C-c 2>/dev/null || true
sleep 0.1
tmux send-keys -t "$PANE_ID" "📨 New task from ${AGENT_NAME:-sender}. Run: cm" Enter

echo "✅ Notified @$TARGET to run 'cm'"
