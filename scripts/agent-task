#!/bin/bash
#
# agent-task - Task queue management (config-driven, deterministic)
# 
# Operates on GLOBAL queue by default for predictability.
# Use --project flag or register projects for automatic discovery.
#
# Config file: ~/.config/kimi/inter-agent-comms/projects
#
# Usage: agent-task <command> [args]

set -e

# ============================================================================
# CONFIGURATION
# ============================================================================

PROJECTS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/kimi/inter-agent-comms/projects"
GLOBAL_QUEUE="$HOME/.local/share/kimi/queue"

# Default queue (global)
QUEUE_ROOT="$GLOBAL_QUEUE"
QUEUE_TYPE="GLOBAL"

# Ensure global queue exists
mkdir -p "$GLOBAL_QUEUE"/{todo,doing,done,.locks}

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

PROJECT_PATH=""
ARGS=()

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --project)
                PROJECT_PATH="$2"
                shift 2
                ;;
            --project=*)
                PROJECT_PATH="${1#*=}"
                shift
                ;;
            *)
                ARGS+=("$1")
                shift
                ;;
        esac
    done
    
    # Set project queue if specified
    if [ -n "$PROJECT_PATH" ]; then
        QUEUE_ROOT="$PROJECT_PATH/.agents/queue"
        QUEUE_TYPE="PROJECT ($(basename "$PROJECT_PATH"))"
        # Re-init directories for project
        TODO_DIR="$QUEUE_ROOT/todo"
        DOING_DIR="$QUEUE_ROOT/doing"
        DONE_DIR="$QUEUE_ROOT/done"
        LOCK_DIR="$QUEUE_ROOT/.locks"
        mkdir -p "$TODO_DIR" "$DOING_DIR" "$DONE_DIR" "$LOCK_DIR"
    fi
}

# ============================================================================
# QUEUE DIRECTORIES (set after parse_args if needed)
# ============================================================================

TODO_DIR="$QUEUE_ROOT/todo"
DOING_DIR="$QUEUE_ROOT/doing"
DONE_DIR="$QUEUE_ROOT/done"
LOCK_DIR="$QUEUE_ROOT/.locks"

# ============================================================================
# LOCKING
# ============================================================================

lock_file() {
    local task_id="$1"
    echo "$LOCK_DIR/${task_id}.lock"
}

try_lock() {
    local task_id="$1"
    local agent="$2"
    local lockfile=$(lock_file "$task_id")
    
    if mkdir "$lockfile" 2>/dev/null; then
        echo "$agent" > "$lockfile/owner"
        echo "$(date -Iseconds)" > "$lockfile/claimed_at"
        echo "$$" > "$lockfile/pid"
        return 0
    else
        if [ -f "$lockfile/pid" ]; then
            local pid=$(cat "$lockfile/pid")
            if ! kill -0 "$pid" 2>/dev/null; then
                echo "[!] Stale lock detected for $task_id, reclaiming..."
                rm -rf "$lockfile"
                mkdir "$lockfile"
                echo "$agent" > "$lockfile/owner"
                echo "$(date -Iseconds)" > "$lockfile/claimed_at"
                echo "$$" > "$lockfile/pid"
                return 0
            fi
        fi
        return 1
    fi
}

unlock() {
    local task_id="$1"
    local lockfile=$(lock_file "$task_id")
    rm -rf "$lockfile"
}

lock_owner() {
    local task_id="$1"
    local lockfile=$(lock_file "$task_id")
    if [ -f "$lockfile/owner" ]; then
        cat "$lockfile/owner"
    else
        echo ""
    fi
}

# ============================================================================
# PROJECT REGISTRY
# ============================================================================

register_project() {
    local project_path="$1"
    
    if [ -z "$project_path" ]; then
        echo "Usage: agent-task register-project <path>"
        exit 1
    fi
    
    # Resolve to absolute path
    project_path=$(cd "$project_path" 2>/dev/null && pwd || echo "$project_path")
    
    if [ ! -d "$project_path" ]; then
        echo "[!] Directory not found: $project_path"
        exit 1
    fi
    
    # Create queue directory if it doesn't exist
    mkdir -p "$project_path/.agents/queue"/{todo,doing,done,.locks}
    
    # Ensure config directory exists
    mkdir -p "$(dirname "$PROJECTS_FILE")"
    
    # Check if already registered
    if [ -f "$PROJECTS_FILE" ] && grep -q "^$project_path$" "$PROJECTS_FILE" 2>/dev/null; then
        echo "[INFO] Project already registered: $project_path"
        return 0
    fi
    
    # Add to registry
    echo "$project_path" >> "$PROJECTS_FILE"
    echo "[OK] Project registered: $project_path"
    echo "   Config: $PROJECTS_FILE"
    echo "   Queue: $project_path/.agents/queue"
}

unregister_project() {
    local project_path="$1"
    
    if [ -z "$project_path" ]; then
        echo "Usage: agent-task unregister-project <path>"
        exit 1
    fi
    
    if [ ! -f "$PROJECTS_FILE" ]; then
        echo "[!] No projects registered"
        exit 1
    fi
    
    # Remove from registry
    grep -v "^$project_path$" "$PROJECTS_FILE" > "$PROJECTS_FILE.tmp" && mv "$PROJECTS_FILE.tmp" "$PROJECTS_FILE"
    echo "[OK] Project unregistered: $project_path"
}

list_projects() {
    echo "Registered projects:"
    echo ""
    
    if [ ! -f "$PROJECTS_FILE" ] || [ ! -s "$PROJECTS_FILE" ]; then
        echo "   (none)"
        echo ""
        echo "Register a project: agent-task register-project /path/to/project"
        return
    fi
    
    local num=1
    while IFS= read -r path; do
        [[ "$path" =~ ^#.*$ ]] && continue
        [ -z "$path" ] && continue
        
        # Expand ~ to $HOME
        eval path="$path"
        
        local status="✓"
        [ ! -d "$path/.agents/queue" ] && status="✗ (no queue)"
        
        echo "   $num. $path $status"
        num=$((num + 1))
    done < "$PROJECTS_FILE"
    echo ""
}

# ============================================================================
# TASK DISCOVERY
# ============================================================================

discover_queues() {
    local queues=("$GLOBAL_QUEUE")
    
    # Add registered project queues
    if [ -f "$PROJECTS_FILE" ]; then
        while IFS= read -r path; do
            [[ "$path" =~ ^#.*$ ]] && continue
            [ -z "$path" ] && continue
            eval path="$path"
            [ -d "$path/.agents/queue" ] && queues+=("$path/.agents/queue")
        done < "$PROJECTS_FILE"
    fi
    
    echo "${queues[@]}"
}

find_task() {
    local task_id="$1"
    
    for queue in $(discover_queues); do
        if [ -f "$queue/todo/${task_id}.md" ]; then
            echo "$queue:todo"
            return 0
        fi
        if [ -f "$queue/doing/${task_id}.md" ]; then
            echo "$queue:doing"
            return 0
        fi
    done
    
    return 1
}

# ============================================================================
# COMMANDS
# ============================================================================

task_id() {
    local title="$1"
    echo "$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')-$(date +%s)"
}

list_tasks() {
    echo "==============================================================="
    echo "TASK QUEUES"
    echo "==============================================================="
    
    # Global queue
    echo ""
    echo "🌐 GLOBAL: ~/.local/share/kimi/queue"
    list_queue_contents "$GLOBAL_QUEUE"
    
    # Registered project queues
    if [ -f "$PROJECTS_FILE" ]; then
        while IFS= read -r path; do
            [[ "$path" =~ ^#.*$ ]] && continue
            [ -z "$path" ] && continue
            eval path="$path"
            
            if [ -d "$path/.agents/queue" ]; then
                echo ""
                echo "📁 $(basename "$path"): $path/.agents/queue"
                list_queue_contents "$path/.agents/queue"
            fi
        done < "$PROJECTS_FILE"
    fi
    
    echo ""
    echo "==============================================================="
}

list_queue_contents() {
    local queue="$1"
    local todo_count=$(ls -1 "$queue/todo"/*.md 2>/dev/null | wc -l)
    local doing_count=$(ls -1 "$queue/doing"/*.md 2>/dev/null | wc -l)
    local done_count=$(ls -1 "$queue/done"/*.md 2>/dev/null | wc -l)
    local has_tasks=0
    
    if [ "$todo_count" -gt 0 ]; then
        echo "   📬 todo: $todo_count"
        has_tasks=1
    fi
    if [ "$doing_count" -gt 0 ]; then
        echo "   🔨 doing: $doing_count"
        has_tasks=1
    fi
    if [ "$done_count" -gt 0 ]; then
        echo "   ✅ done: $done_count"
        has_tasks=1
    fi
    
    if [ "$has_tasks" -eq 0 ]; then
        echo "   (empty)"
    fi
}

create_task() {
    local title="$1"
    local assignee="${2:-any}"
    
    if [ -z "$title" ]; then
        echo "Usage: agent-task create <title> [assignee]"
        echo "       agent-task create --project <path> <title> [assignee]"
        exit 1
    fi
    
    local id=$(task_id "$title")
    local file="$TODO_DIR/${id}.md"
    
    cat > "$file" << EOF
# Task: $title

**ID:** $id
**Created:** $(date -Iseconds)
**Status:** pending
**Assignee:** $assignee

## Description
[Add task description here]

## Acceptance Criteria
- [ ] Criterion 1
- [ ] Criterion 2

## Notes
EOF

    echo "[CREATED] Task: $id"
    echo "   File: $file"
    echo "   Queue: $QUEUE_TYPE"
}

claim_task() {
    local task_id="$1"
    local agent="$2"
    
    if [ -z "$task_id" ] || [ -z "$agent" ]; then
        echo "Usage: agent-task claim <task-id> <agent-name>"
        exit 1
    fi
    
    # Find task in any queue
    local location
    location=$(find_task "$task_id") || {
        echo "[!] Task not found in any queue: $task_id"
        exit 1
    }
    
    local queue_path="${location%:*}"
    local state="${location#*:}"
    
    if [ "$state" != "todo" ]; then
        echo "[!] Task is not available for claim (current state: $state)"
        exit 1
    fi
    
    local lock_dir="$queue_path/.locks"
    mkdir -p "$lock_dir"
    
    local task_file="$queue_path/todo/${task_id}.md"
    local doing_dir="$queue_path/doing"
    local lockfile="$lock_dir/${task_id}.lock"
    
    if mkdir "$lockfile" 2>/dev/null; then
        echo "$agent" > "$lockfile/owner"
        echo "$(date -Iseconds)" > "$lockfile/claimed_at"
        echo "$$" > "$lockfile/pid"
        
        mv "$task_file" "$doing_dir/"
        echo "" >> "$doing_dir/${task_id}.md"
        echo "---" >> "$doing_dir/${task_id}.md"
        echo "Claimed by: $agent at $(date -Iseconds)" >> "$doing_dir/${task_id}.md"
        
        echo "[OK] Task claimed: $task_id"
        echo "   Agent: $agent"
        echo "   Queue: $queue_path"
    else
        local owner=""
        [ -f "$lockfile/owner" ] && owner=$(cat "$lockfile/owner")
        echo "[!] Task already claimed by: $owner"
        exit 1
    fi
}

complete_task() {
    local task_id="$1"
    
    if [ -z "$task_id" ]; then
        echo "Usage: agent-task complete <task-id>"
        exit 1
    fi
    
    local location
    location=$(find_task "$task_id") || {
        echo "[!] Task not found in any queue: $task_id"
        exit 1
    }
    
    local queue_path="${location%:*}"
    local state="${location#*:}"
    
    if [ "$state" != "doing" ]; then
        echo "[!] Task must be in 'doing' state to complete (current: $state)"
        echo "   Claim it first: agent-task claim $task_id <agent>"
        exit 1
    fi
    
    local doing_file="$queue_path/doing/${task_id}.md"
    local done_dir="$queue_path/done"
    local lock_dir="$queue_path/.locks"
    
    echo "" >> "$doing_file"
    echo "---" >> "$doing_file"
    echo "Completed at: $(date -Iseconds)" >> "$doing_file"
    mv "$doing_file" "$done_dir/"
    rm -rf "$lock_dir/${task_id}.lock"
    
    echo "[OK] Task completed: $task_id"
    echo "   Queue: $queue_path"
}

# ============================================================================
# MAIN
# ============================================================================

parse_args "$@"
set -- "${ARGS[@]}"

case "${1:-list}" in
    list|ls)
        list_tasks
        ;;
    create)
        shift
        create_task "$@"
        ;;
    claim)
        shift
        claim_task "$@"
        ;;
    complete)
        shift
        complete_task "$@"
        ;;
    register-project)
        shift
        register_project "$@"
        ;;
    unregister-project)
        shift
        unregister_project "$@"
        ;;
    projects)
        list_projects
        ;;
    *)
        echo "Usage: agent-task <command> [args]"
        echo ""
        echo "Task Commands:"
        echo "  list                              - Show all tasks across all queues"
        echo "  create <title> [agent]            - Create task in global queue"
        echo "  create --project <path> <title>   - Create task in project queue"
        echo "  claim <id> <agent>                - Claim a task (searches all queues)"
        echo "  complete <id>                     - Complete a task (searches all queues)"
        echo ""
        echo "Project Management:"
        echo "  register-project <path>           - Register project for task queues"
        echo "  unregister-project <path>         - Unregister project"
        echo "  projects                          - List registered projects"
        echo ""
        echo "Config file: ~/.config/kimi/inter-agent-comms/projects"
        ;;
esac
